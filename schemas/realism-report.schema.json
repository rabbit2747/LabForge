        "industry": {
          "title": "Industry",
          "type": "string"
        },
        "display_name": {
          "title": "Display Name",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "required_zones": {
          "items": {
            "type": "string"
          },
          "title": "Required Zones",
          "type": "array"
        },
        "capabilities": {
