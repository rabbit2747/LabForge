            "warning",
            "error"
          ],
          "title": "Severity",
          "type": "string"
        },
        "category": {
          "title": "Category",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "expected": {
          "default": "",
          "title": "Expected",
          "type": "string"
