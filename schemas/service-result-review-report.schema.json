      "title": "Errors",
      "type": "array"
    },
    "open_questions": {
      "items": {
        "anyOf": [
          {
            "additionalProperties": true,
            "type": "object"
          },
          {
            "type": "string"
          }
        ]
      },
      "title": "Open Questions",
      "type": "array"
    }
  },
  "required": [
    "lab_id",
    "result_file",
    "status"
  ],
  "title": "ServiceResultReviewReport",
  "type": "object"
}
