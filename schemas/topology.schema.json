{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LabForge Topology",
  "type": "object",
  "required": ["networks", "services"],
  "properties": {
    "networks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {"type": "string"},
          "internal": {"type": "boolean"}
        }
      }
    },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "networks", "healthcheck"],
        "properties": {
          "name": {"type": "string"},
          "role": {"type": "string"},
          "exposed": {"type": "boolean"},
          "networks": {"type": "array", "items": {"type": "string"}},
          "healthcheck": {"type": "object"}
        }
      }
    }
  }
}

